---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getGroupedNotesByDate } from "@/utils/content-utils";
import { getFileDirFromPath, getPostUrlBySlug } from "@/utils/url-utils";
import CoverImage from "@/components/common/CoverImage.astro";

const noteGroups = await getGroupedNotesByDate();

function formatDateLabel(date: Date) {
	return new Intl.DateTimeFormat("zh-CN", {
		hour: "2-digit",
		minute: "2-digit",
	}).format(date);
}
---

<MainGridLayout title={i18n(I18nKey.noteStream)} description={i18n(I18nKey.noteStreamDescription)}>
	<div class="space-y-4">
		<div class="card-base rounded-(--radius-large) px-6 py-6 md:px-9">
			<div class="flex items-start gap-4">
				<div class="h-12 w-12 rounded-2xl bg-(--primary) text-white dark:text-black/70 flex items-center justify-center shrink-0">
					<Icon name="material-symbols:dynamic-feed-rounded" class="text-2xl" />
				</div>
				<div>
					<div class="text-3xl font-bold text-90 mb-2">{i18n(I18nKey.noteStream)}</div>
					<p class="text-60 leading-7">{i18n(I18nKey.noteStreamDescription)}</p>
				</div>
			</div>
		</div>

		<div class="relative pl-4 md:pl-8">
			<div class="absolute left-[1.35rem] md:left-[2.2rem] top-0 bottom-0 w-px bg-(--line-divider)"></div>
			<div class="space-y-5">
				{noteGroups.map((group) => (
					<section class="relative ml-6 md:ml-10">
						<div class="sticky top-22 z-10 mb-4 inline-flex items-center gap-2 rounded-full bg-(--card-bg) px-4 py-2 text-sm font-medium text-75 shadow-sm border border-(--line-divider)">
							<Icon name="material-symbols:calendar-month-rounded" class="text-base text-(--primary)" />
							<span>{group.label}</span>
							<span class="text-50">· {group.items.length} 条</span>
						</div>
						<div class="space-y-4">
							{group.items.map((note) => {
								const galleryImages = note.data.noteImages || [];
								const firstImage = note.data.image || galleryImages[0] || "";
								const allImages = galleryImages.length > 0
									? galleryImages
									: firstImage
										? [firstImage]
										: [];

								return (
									<article class="relative card-base rounded-(--radius-large) px-5 py-5 md:px-7 md:py-6">
										<div class="absolute -left-[2.15rem] md:-left-[2.95rem] top-8 h-4 w-4 rounded-full bg-(--primary) outline outline-4 outline-(--card-bg)"></div>
										<div class="flex flex-wrap items-center gap-3 text-sm text-50 mb-3">
											<span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[oklch(0.95_0.025_var(--hue))] dark:bg-[oklch(0.25_0.025_var(--hue))] text-(--primary)">
												<Icon name="material-symbols:schedule-rounded" class="text-base" />
												{formatDateLabel(note.data.published)}
											</span>
											{note.data.category && (
												<span class="inline-flex items-center px-3 py-1 rounded-full bg-black/5 dark:bg-white/8">
													{note.data.category}
												</span>
											)}
											{note.data.noteMood && (
												<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-black/5 dark:bg-white/8">
													<Icon name="material-symbols:mood-rounded" class="text-base" />
													{note.data.noteMood}
												</span>
											)}
											{note.data.noteLocation && (
												<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-black/5 dark:bg-white/8">
													<Icon name="material-symbols:location-on-outline-rounded" class="text-base" />
													{note.data.noteLocation}
												</span>
											)}
											{note.data.noteWeather && (
												<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-black/5 dark:bg-white/8">
													<Icon name="material-symbols:partly-cloudy-day-outline-rounded" class="text-base" />
													{note.data.noteWeather}
												</span>
											)}
										</div>

										<h2 class="text-xl md:text-2xl font-bold text-90 mb-3">
											<a href={getPostUrlBySlug(note.id)} class="hover:text-(--primary) transition-colors">
												{note.data.title}
											</a>
										</h2>

										{note.data.description && (
											<p class="text-75 leading-7 whitespace-pre-line mb-4">{note.data.description}</p>
										)}

										{allImages.length > 0 && (
											<div class:list={["grid gap-3 mb-4", allImages.length === 1 ? "grid-cols-1" : "grid-cols-2 md:grid-cols-3"]}>
												{allImages.map((image) => (
													<div class="overflow-hidden rounded-2xl bg-black/5 dark:bg-white/5 aspect-square">
														<CoverImage
															src={image}
															basePath={getFileDirFromPath(note.filePath || "")}
															alt={note.data.title}
															class="w-full h-full object-cover"
															preview={true}
														/>
													</div>
												))}
											</div>
										)}

										<div class="flex flex-wrap items-center justify-between gap-3">
											<div class="flex flex-wrap gap-2 text-sm text-50">
												{note.data.tags.map((tag) => (
													<span class="px-2.5 py-1 rounded-full bg-black/5 dark:bg-white/8">#{tag}</span>
												))}
											</div>
											<a href={getPostUrlBySlug(note.id)} class="inline-flex items-center gap-1.5 text-sm font-medium text-(--primary)">
												阅读详情
												<Icon name="fa7-solid:arrow-right" class="text-xs" />
											</a>
										</div>
									</article>
								);
							})}
						</div>
					</section>
				))}
			</div>
		</div>
	</div>
</MainGridLayout>
